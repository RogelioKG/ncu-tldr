#!/bin/sh
set -e

# Colors
R='\033[1;31m'
G='\033[1;32m'
B='\033[1;34m'
Y='\033[1;33m'
N='\033[0m'

print_msg() {
    printf "$1$2${N}\n"
}

run_checks() {
    DIR="$1"
    LABEL="$2"
    LINT_CMD="$3"
    FIX_CMD="$4"
    FORMAT_CMD="$5"
    FORMAT_FIX_CMD="$6"

    cd "$DIR"
    FAILED=0

    print_msg "$B" "🔄 [${LABEL}] Linting..."
    if [ -n "$LINT_CMD" ]; then
        if ! sh -c "$LINT_CMD"; then
            FAILED=1
            echo ""
            print_msg "$Y" "💡 [${LABEL}] To automatically fix lint issues, run:"
            print_msg "$N" "    $FIX_CMD"
        fi
    fi

    if [ -n "$FORMAT_CMD" ]; then
        print_msg "$B" "🔄 [${LABEL}] Formatting..."
        if ! sh -c "$FORMAT_CMD"; then
            FAILED=1
            echo ""
            print_msg "$Y" "💡 [${LABEL}] To automatically fix formatting issues, run:"
            print_msg "$N" "    $FORMAT_FIX_CMD"
        fi
    fi

    if [ "$FAILED" -eq 1 ]; then
        echo ""
        print_msg "$R" "❌ [${LABEL}] Checks failed. Fix the issues above, then re-commit."
        exit 1
    fi

    cd ..
}

print_msg "$G" "🚀 [Pre-commit] Starting checks..."

if git diff --cached --name-only | grep -q "^backend/"; then
    run_checks \
        "backend" \
        "Backend" \
        "pnpm run backend:lint" \
        "pnpm run backend:lint:fix" \
        "pnpm run backend:format" \
        "pnpm run backend:format:fix"
else
    print_msg "$Y" "⏭️  [Backend] No changes detected. Skipping..."
fi

if git diff --cached --name-only | grep -q "^frontend/"; then
    run_checks \
        "frontend" \
        "Frontend" \
        "pnpm run lint" \
        "pnpm run frontend:lint:fix" \
        "" \
        ""
else
    print_msg "$Y" "⏭️  [Frontend] No changes detected. Skipping..."
fi

print_msg "$G" "✅ [Pre-commit] All checks passed. Committing..."
