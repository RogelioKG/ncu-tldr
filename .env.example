POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ncu_tldr

# Required for backend startup (must be non-empty)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
JWT_SECRET_KEY=change-me-in-production
X_SYNC_SECRET_KEY=change-me-in-production

VITE_API_BASE_URL=http://127.0.0.1:8000

# 可填入來覆蓋預設值，或留空以使用預設值
ACCESS_TOKEN_EXPIRE_MINUTES=
REMEMBER_ME_EXPIRE_MINUTES=


# AWS SES（勿將真實 key 提交至版控）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
EMAIL_FROM=NCU-TLDR <noreply@ncutldr.com>
VERIFY_BASE_URL=https://ncutldr.com
