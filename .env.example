POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ncu_tldr

# 必填 (Required for backend startup) - 勿留空
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
JWT_SECRET_KEY=change-me-in-production
X_SYNC_SECRET_KEY=change-me-in-production

VITE_API_BASE_URL=http://127.0.0.1:8000

# 可填入來覆蓋預設值，或留空以使用預設值
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=
REFRESH_TOKEN_REMEMBER_ME_EXPIRE_DAYS=3

# Logging and CORS (可選，有預設值)
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Cookie settings (可選，有預設值)
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Database (可選，有預設值)
SQLALCHEMY_ECHO=false


# AWS SES - 必填 (勿將真實 key 提交至版控)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
EMAIL_FROM=NCU-TLDR <noreply@ncutldr.com>
VERIFY_BASE_URL=https://ncutldr.com
